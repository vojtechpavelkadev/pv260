@page "/"

<PageTitle>Dino Jump</PageTitle>

<div class="game-container" tabindex="0" @onkeydown="OnKeyDown" @onclick="OnClick" @ref="gameDiv">
    @if (!gameStarted)
    {
        <div class="overlay">
            <h2>🦕 Dino Jump</h2>
            <p>Press <b>Space</b> or <b>Click</b> to Start</p>
        </div>
    }
    else if (gameOver)
    {
        <div class="overlay">
            <h2>Game Over!</h2>
            <p>Score: @score</p>
            <p>Press <b>Space</b> or <b>Click</b> to Restart</p>
        </div>
    }

    <div class="score-display">
        <span>Score: @score</span>
        @if (bestScore > 0)
        {
            <span class="best-score">Best: @bestScore</span>
        }
        <span class="speed-badge" style="background:@SpeedColor">⚡ @SpeedLabel</span>
    </div>

    <div class="player" style="bottom: @(GroundHeight + (int)playerY)px;">🦕</div>

    @foreach (var obs in obstacles)
    {
        <div class="obstacle" style="left: @((int)obs.X)px; font-size: @(obs.Height)px;">🌵</div>
    }

    <div class="ground"></div>
</div>

<p class="ai-disclaimer">100% C# only ⚠️ This game was generated by <b>GitHub Copilot</b> (AI). </p>

<style>
    .game-container {
        position: relative;
        width: 800px;
        height: 300px;
        border: 2px solid #333;
        overflow: hidden;
        background: linear-gradient(to bottom, #87CEEB 70%, #F4A460 100%);
        outline: none;
        cursor: pointer;
        margin: 20px auto;
        user-select: none;
        border-radius: 8px;
    }

    .overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background: rgba(0,0,0,0.55);
        color: white;
        z-index: 10;
    }

    .score-display {
        position: absolute;
        top: 10px;
        right: 15px;
        font-size: 16px;
        font-weight: bold;
        color: #333;
        z-index: 5;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 3px;
    }

    .best-score {
        font-size: 12px;
        color: #666;
    }

    .speed-badge {
        font-size: 11px;
        color: white;
        padding: 1px 6px;
        border-radius: 8px;
        transition: background 0.5s;
    }

    .player {
        position: absolute;
        left: 80px;
        font-size: 40px;
        line-height: 1;
        z-index: 2;
    }

    .obstacle {
        position: absolute;
        bottom: 40px;
        line-height: 1;
        z-index: 2;
    }

    .ground {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        background: #8B4513;
        border-top: 3px solid #654321;
    }

    .ai-disclaimer {
        text-align: center;
        font-size: 13px;
        color: #777;
        margin-top: 8px;
        font-style: italic;
    }
</style>
